# Required for better API enrichment
# These are auto-loaded from stroke_open_science/.env or stroke_open_science/configs/.env
OPENALEX_MAILTO=you@example.com
OPENALEX_API_KEY=
NCBI_EMAIL=you@example.com
NCBI_API_KEY=
UNPAYWALL_EMAIL=you@example.com
GITHUB_TOKEN=

# Optional local snapshot joins for serious runs
# Relative paths are resolved from the stroke_open_science repo root.
UNPAYWALL_SNAPSHOT=data/unpaywall/*.parquet
CROSSREF_RELATIONS=data/crossref/*.parquet

# LLM provider selection
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
EMBEDDING_DEVICE=auto

# Ollama settings (if using local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
